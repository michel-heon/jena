@prefix fuseki: <http://jena.apache.org/fuseki#> .
@prefix grag:   <https://jena.apache.org/graphrag/vocab#> .
@prefix tdb2:   <http://jena.apache.org/2016/tdb#> .

<#service> a fuseki:Service ;
    fuseki:name          "ds" ;
    fuseki:dataset       <#dataset> ;
    grag:enableGraphRAG  true ;
    grag:graphragIndex   <#graphragIndex> .

<#graphragIndex> a grag:GraphRAGIndex ;
    grag:textIndexDir     "target/run/graphrag/text-index" ;
    grag:vectorIndexDir   "target/run/graphrag/vector-index" ;
    grag:vectorDimension  384 .

<#dataset> a tdb2:DatasetTDB2 ;
    tdb2:location "target/run/graphrag/database" .